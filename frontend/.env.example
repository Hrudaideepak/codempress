# Frontend environment (safe to commit — no secrets)
# Set VITE_API_URL to your deployed backend, e.g. https://skillforge.onrender.com/api
# Leave as /api for local dev (uses the Vite proxy to localhost:8000)
VITE_API_URL=/api
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
