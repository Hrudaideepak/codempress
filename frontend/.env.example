# ---------------------------------------------------------------------------
# Codempress — Frontend environment variables (Vite)
# Copy this file to `.env` and fill in real values for local/dev.
# NEVER commit `.env` (it is gitignored). This file is safe to commit.
# ---------------------------------------------------------------------------

# API base path.  In dev, Vite proxies `/api` -> http://localhost:8000.
# In production (Vercel) leave as `/api` (rewritten to the Render backend).
VITE_API_URL=/api

# Google OAuth client ID (from Google Cloud Console — "OAuth 2.0 Client ID").
# Used by the Auth page + backend audience check.
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Supabase project (public anon key — safe to expose in the browser).
VITE_SUPABASE_URL=https://edvbfwnjqmibsotcqtqe.supabase.co
